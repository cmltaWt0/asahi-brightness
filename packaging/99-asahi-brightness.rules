ACTION=="add", SUBSYSTEM=="backlight", KERNEL=="apple-panel-bl", \
    RUN+="/usr/bin/chgrp video /sys/class/backlight/%k/brightness", \
    RUN+="/usr/bin/chmod g+w /sys/class/backlight/%k/brightness"

ACTION=="add", SUBSYSTEM=="leds", KERNEL=="kbd_backlight", \
    RUN+="/usr/bin/chgrp video /sys/class/leds/%k/brightness", \
    RUN+="/usr/bin/chmod g+w /sys/class/leds/%k/brightness"
